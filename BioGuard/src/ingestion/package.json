{
  "name": "@bioguardian/ingestion",
  "version": "1.0.0",
  "description": "BioGuardian Clinical Intelligence Infrastructure — Ingestion Layer. gRPC telemetry gateway, FHIR R4 normalization, WebSocket bridge, and SHA-256 audit chain for on-device biometric stream processing.",
  "main": "server.js",
  "author": "BioGuardian Engineering",
  "license": "UNLICENSED",
  "private": true,
  "type": "commonjs",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon --watch . --ext js,proto,yaml --ignore '*.test.js' server.js",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --runInBand --forceExit",
    "lint": "eslint . --ext .js --max-warnings 0",
    "lint:fix": "eslint . --ext .js --fix",
    "proto:check": "node -e \"require('@grpc/proto-loader').loadSync('proto/telemetry.proto'); console.log('Proto OK');\"",
    "audit:verify": "node scripts/verify_audit_chain.js",
    "health": "node scripts/health_check.js"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.12.0",
    "@grpc/proto-loader": "^0.7.15",
    "axios": "^1.9.0",
    "socket.io": "^4.8.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js",
      "**/__tests__/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "*.js",
      "!scripts/**",
      "!jest.config.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  },
  "keywords": [
    "bioguardian",
    "grpc",
    "fhir",
    "loinc",
    "healthkit",
    "telemetry",
    "biometrics",
    "clinical-intelligence",
    "adverse-drug-events",
    "on-device"
  ]
}
